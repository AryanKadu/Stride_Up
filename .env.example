# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it's in .gitignore.

# Database (only needed for production / Supabase PostgreSQL)
# DB_URI=postgresql://user:password@host:port/dbname

# API Keys
USDA_API_KEY=your-usda-api-key-here
API_NINJAS_KEY=your-api-ninjas-key-here

# Django superuser (used by build.sh on Render deploy — optional)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=your-secure-password
# DJANGO_SUPERUSER_EMAIL=admin@example.com
